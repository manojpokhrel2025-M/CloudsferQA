@model CloudsferQA.Models.ViewModels.TestViewModel
@{
    Layout = null;

    // Build lookup structures
    var resultDict = Model.Results.ToDictionary(r => r.TestCaseId);

    // Active modules (in defined order, only those that have test cases)
    var activeModules = Model.ModuleOrder
        .Where(m => Model.TestCases.Any(tc => tc.Module == m))
        .ToList();

    // Group: module → submodule → cases
    var grouped = activeModules.ToDictionary(
        m => m,
        m => Model.TestCases
            .Where(tc => tc.Module == m)
            .GroupBy(tc => tc.Submodule)
            .ToDictionary(g => g.Key, g => g.ToList())
    );

    // Header stats
    int totalCases  = Model.TestCases.Count;
    int passCount   = Model.Results.Count(r => r.Status == "pass");
    int failCount   = Model.Results.Count(r => r.Status == "fail");
    int blockedCount = Model.Results.Count(r => r.Status == "blocked");
    int testedCount  = Model.Results.Count(r => r.Status != "pending");
    double progressPct = totalCases > 0 ? (double)testedCount / totalCases * 100 : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Test Session — CloudsferQA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body class="test-body">

<!-- ── Fixed Header ──────────────────────────────────────────────────────── -->
<header class="test-header">
    <div class="header-left">
        <img src="/images/logo.svg" alt="Cloudsfer" height="30" class="header-logo">
    </div>

    <div class="header-center">
        <span class="session-info">
            <strong>@Model.Session.Tester</strong>
            <span class="sep">·</span>@Model.Session.Version
            <span class="sep">·</span>@Model.Session.Environment
        </span>
        <div class="header-progress-wrap">
            <div class="header-progress-bar">
                <div class="header-progress-fill" id="progressBar" style="width:@progressPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
            </div>
            <span class="progress-label" id="progressLabel">@testedCount / @totalCases tested</span>
        </div>
    </div>

    <div class="header-right">
        <span class="chip chip-pass" id="chipPass">@passCount Pass</span>
        <span class="chip chip-fail" id="chipFail">@failCount Fail</span>
        <span class="chip chip-blocked" id="chipBlocked">@blockedCount Blocked</span>
        <button type="button" onclick="openExportModal()" class="btn-export" style="cursor:pointer;font-family:inherit">↓ Export</button>
        <a href="/Dashboard" class="btn-export" style="background:rgba(255,255,255,.1)">Dashboard</a>
        @if (Model.Session.CompletedAt == null)
        {
            <button type="button" onclick="openCompleteModal()" class="btn-export" style="background:#43A047;border-color:#388E3C;cursor:pointer;font-family:inherit;font-weight:600">
                ✓ Complete
            </button>
        }
        else
        {
            <span class="btn-export" style="background:#388E3C;border-color:#2E7D32;opacity:.8;cursor:default">✓ Completed</span>
        }
        <form method="post" action="/Auth/Logout" style="display:inline;margin:0">
            <button type="submit" class="btn-export" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.2);cursor:pointer;font-family:inherit">
                Logout
            </button>
        </form>
    </div>
</header>

<!-- ── Fixed Sidebar ─────────────────────────────────────────────────────── -->
<nav class="sidebar" id="sidebar">
    <div class="sidebar-search-wrap">
        <input type="text" id="moduleSearch" class="sidebar-search" placeholder="Search modules…" autocomplete="off">
    </div>

    <div class="module-list" id="moduleList">
        @foreach (var module in activeModules)
        {
            var submodules = grouped[module];
            <div class="module-group" data-module="@module">
                <div class="module-header">
                    <span class="module-name">@module</span>
                    <span class="module-chevron">▾</span>
                </div>
                <div class="module-items">
                    @foreach (var (submodule, cases) in submodules)
                    {
                        int done = cases.Count(tc =>
                            resultDict.TryGetValue(tc.Id, out var r) && r.Status != "pending");
                        <div class="submodule-item"
                             data-module="@module"
                             data-submodule="@submodule">
                            <span class="submodule-name">@submodule</span>
                            <span class="submodule-badge" id="badge-@(module.GetHashCode())-@(submodule.GetHashCode())">@done/@cases.Count</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</nav>

<!-- ── Main Content ───────────────────────────────────────────────────────── -->
<main class="test-main" id="testMain">

    <div class="content-header" id="contentHeader">
        <div class="content-header-left">
            <div class="breadcrumb-text" id="breadcrumb">Select a module from the sidebar</div>
            <h2 class="content-title" id="currentSubmodule"></h2>
        </div>
        <div class="content-header-actions">
            <button class="btn-bulk btn-bulk-pass" id="btnMarkAllPass">✓ Mark All Pass</button>
            <button class="btn-bulk btn-bulk-skip" id="btnSkipAll">⊘ Skip All</button>
        </div>
    </div>

    <div class="filter-bar" id="filterBar">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="pending">Pending</button>
        <button class="filter-btn" data-filter="pass">Pass</button>
        <button class="filter-btn" data-filter="fail">Fail</button>
        <button class="filter-btn" data-filter="blocked">Blocked</button>
        <button class="filter-btn" data-filter="skip">Skip</button>
    </div>

    <div class="cards-container" id="cardsContainer">
        @foreach (var module in activeModules)
        {
            var submodules = grouped[module];
            foreach (var (submodule, cases) in submodules)
            {
                foreach (var tc in cases)
                {
                    resultDict.TryGetValue(tc.Id, out var result);
                    var status  = result?.Status ?? "pending";
                    var notes   = result?.Notes ?? "";
                    var hasDetails = !string.IsNullOrWhiteSpace(tc.Steps) || !string.IsNullOrWhiteSpace(tc.ExpectedResult);

                    <div class="test-card status-@status"
                         data-test-id="@tc.Id"
                         data-module="@module"
                         data-submodule="@submodule"
                         data-status="@status"
                         style="display:none">

                        <div class="card-top-row">
                            <span class="badge-tc">@tc.Id</span>
                            <span class="badge-priority priority-@(tc.Priority.ToLower())">@tc.Priority</span>
                            <span class="badge-status status-badge-@status" id="status-@tc.Id">@status</span>
                        </div>

                        <div class="card-scenario">@tc.Scenario</div>

                        @if (hasDetails)
                        {
                            <div class="card-details" id="details-@tc.Id">
                                @if (!string.IsNullOrWhiteSpace(tc.Steps))
                                {
                                    <div class="detail-block">
                                        <div class="detail-label">Steps</div>
                                        <div class="detail-text">@tc.Steps</div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(tc.ExpectedResult))
                                {
                                    <div class="detail-block">
                                        <div class="detail-label">Expected Result</div>
                                        <div class="detail-text">@tc.ExpectedResult</div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="card-action-row">
                            <div class="action-btns">
                                <button class="btn-action btn-pass @(status == "pass" ? "active" : "")"
                                        data-test-id="@tc.Id" data-status="pass">Pass</button>
                                <button class="btn-action btn-fail @(status == "fail" ? "active" : "")"
                                        data-test-id="@tc.Id" data-status="fail">Fail</button>
                                <button class="btn-action btn-blocked @(status == "blocked" ? "active" : "")"
                                        data-test-id="@tc.Id" data-status="blocked">Blocked</button>
                                <button class="btn-action btn-skip @(status == "skip" ? "active" : "")"
                                        data-test-id="@tc.Id" data-status="skip">Skip</button>
                            </div>

                            <input type="text"
                                   class="notes-input"
                                   placeholder="Add notes…"
                                   value="@notes"
                                   data-test-id="@tc.Id">

                            @if (hasDetails)
                            {
                                <button class="btn-details" data-target="details-@tc.Id">Details ▴</button>
                            }
                        </div>

                    </div>
                }
            }
        }
    </div>

    <div class="empty-state" id="emptyState" style="display:none">
        <div class="empty-icon">🔍</div>
        <div class="empty-text">No test cases match the current filter.</div>
    </div>
</main>

<script src="/js/test.js?v=2"></script>

<!-- Export Modal -->
<div id="exportModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.45);align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:12px;width:480px;max-width:95vw;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 8px 32px rgba(0,0,0,.2)">

        <!-- Header -->
        <div style="background:#1565C0;border-radius:12px 12px 0 0;padding:14px 20px;display:flex;align-items:center;justify-content:space-between">
            <span style="color:#fff;font-weight:700;font-size:14px">Export Test Cases</span>
            <button onclick="closeExportModal()" style="background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1;padding:0">×</button>
        </div>

        <!-- Body -->
        <div style="padding:20px;overflow-y:auto;flex:1">
            <div style="font-size:12px;font-weight:600;color:#546E7A;margin-bottom:10px">SELECT MODULES TO EXPORT</div>

            <!-- Select All toggle -->
            <label style="display:flex;align-items:center;gap:8px;padding:8px 10px;background:#F5F5F5;border-radius:6px;cursor:pointer;margin-bottom:8px;font-size:13px;font-weight:600;color:#37474F">
                <input type="checkbox" id="exportSelectAll" onchange="toggleAllModules(this)" checked style="width:15px;height:15px">
                All Modules
            </label>

            <div id="exportModuleList" style="display:flex;flex-direction:column;gap:4px">
                @foreach (var m in activeModules)
                {
                    var count = Model.TestCases.Count(tc => tc.Module == m);
                    <label style="display:flex;align-items:center;gap:8px;padding:7px 10px;border:1px solid #E0E0E0;border-radius:6px;cursor:pointer;font-size:13px;color:#37474F" class="export-module-item">
                        <input type="checkbox" class="export-module-cb" value="@m" checked style="width:14px;height:14px" onchange="updateSelectAll()">
                        <span style="flex:1">@m</span>
                        <span style="font-size:11px;color:#90A4AE">@count cases</span>
                    </label>
                }
            </div>
        </div>

        <!-- Footer -->
        <div style="padding:14px 20px;border-top:1px solid #F0F0F0;display:flex;gap:8px;justify-content:flex-end">
            <button onclick="closeExportModal()" style="background:#ECEFF1;border:none;border-radius:6px;padding:7px 18px;font-size:13px;color:#546E7A;cursor:pointer;font-weight:600">Cancel</button>
            <button onclick="doExport('csv')" style="background:#37474F;border:none;border-radius:6px;padding:7px 16px;font-size:13px;color:#fff;cursor:pointer;font-weight:600">↓ Export CSV</button>
            <button onclick="doExport('excel')" style="background:#1565C0;border:none;border-radius:6px;padding:7px 16px;font-size:13px;color:#fff;cursor:pointer;font-weight:600">↓ Export Excel</button>
        </div>
    </div>
</div>

<!-- Complete Modal -->
<div id="completeModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.45);align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:12px;width:480px;max-width:95vw;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 8px 32px rgba(0,0,0,.2)">

        <!-- Header -->
        <div style="background:#2E7D32;border-radius:12px 12px 0 0;padding:14px 20px;display:flex;align-items:center;justify-content:space-between">
            <span style="color:#fff;font-weight:700;font-size:14px">✓ Complete Session</span>
            <button onclick="closeCompleteModal()" style="background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1;padding:0">×</button>
        </div>

        <!-- Body -->
        <div style="padding:20px;overflow-y:auto;flex:1">
            <div style="font-size:13px;color:#546E7A;margin-bottom:14px;line-height:1.6">
                Select which modules were tested in this session. Then click <strong>Mark as Completed</strong> to finalise.
            </div>

            <div style="font-size:12px;font-weight:600;color:#546E7A;margin-bottom:10px">MODULES TESTED</div>

            <!-- Select All toggle -->
            <label style="display:flex;align-items:center;gap:8px;padding:8px 10px;background:#F5F5F5;border-radius:6px;cursor:pointer;margin-bottom:8px;font-size:13px;font-weight:600;color:#37474F">
                <input type="checkbox" id="completeSelectAll" onchange="toggleAllCompleteModules(this)" checked style="width:15px;height:15px">
                All Modules
            </label>

            <div id="completeModuleList" style="display:flex;flex-direction:column;gap:4px">
                @foreach (var m in activeModules)
                {
                    var total  = Model.TestCases.Count(tc => tc.Module == m);
                    var tested = Model.Results.Count(r => Model.TestCases.Any(tc => tc.Module == m && tc.Id == r.TestCaseId) && r.Status != "pending");
                    var pct    = total > 0 ? (int)((double)tested / total * 100) : 0;
                    var pillColor = pct == 100 ? "#E8F5E9" : pct > 0 ? "#FFF3E0" : "#F5F5F5";
                    var textColor = pct == 100 ? "#2E7D32" : pct > 0 ? "#E65100" : "#90A4AE";
                    <label style="display:flex;align-items:center;gap:8px;padding:7px 10px;border:1px solid #E0E0E0;border-radius:6px;cursor:pointer;font-size:13px;color:#37474F" class="complete-module-item">
                        <input type="checkbox" class="complete-module-cb" value="@m" checked style="width:14px;height:14px" onchange="updateCompleteSelectAll()">
                        <span style="flex:1">@m</span>
                        <span style="font-size:11px;background:@pillColor;color:@textColor;padding:2px 8px;border-radius:10px;font-weight:600">@tested/@total tested</span>
                    </label>
                }
            </div>
        </div>

        <!-- Footer -->
        <div style="padding:14px 20px;border-top:1px solid #F0F0F0;display:flex;gap:8px;justify-content:flex-end">
            <button onclick="closeCompleteModal()" style="background:#ECEFF1;border:none;border-radius:6px;padding:7px 18px;font-size:13px;color:#546E7A;cursor:pointer;font-weight:600">Cancel</button>
            <button onclick="confirmComplete()" style="background:#2E7D32;border:none;border-radius:6px;padding:7px 20px;font-size:13px;color:#fff;cursor:pointer;font-weight:600">✓ Mark as Completed</button>
        </div>
    </div>
</div>

<!-- Hidden complete form -->
<form id="completeForm" method="post" action="/Session/Complete" style="display:none"></form>

<script>
    function openExportModal() {
        const modal = document.getElementById('exportModal');
        modal.style.display = 'flex';
    }
    function closeExportModal() {
        document.getElementById('exportModal').style.display = 'none';
    }
    function toggleAllModules(cb) {
        document.querySelectorAll('.export-module-cb').forEach(c => c.checked = cb.checked);
    }
    function updateSelectAll() {
        const all = document.querySelectorAll('.export-module-cb');
        const checked = document.querySelectorAll('.export-module-cb:checked');
        document.getElementById('exportSelectAll').checked = all.length === checked.length;
        document.getElementById('exportSelectAll').indeterminate = checked.length > 0 && checked.length < all.length;
    }
    function doExport(format) {
        const selected = [...document.querySelectorAll('.export-module-cb:checked')].map(c => c.value);
        if (selected.length === 0) { alert('Please select at least one module.'); return; }
        const params = new URLSearchParams();
        params.append('sessionId', '@Model.Session.Id');
        selected.forEach(m => params.append('modules', m));
        const url = format === 'csv' ? '/Test/ExportCsv?' : '/Test/Export?';
        window.open(url + params.toString(), '_blank');
        closeExportModal();
    }
    // Close export modal on backdrop click
    document.getElementById('exportModal').addEventListener('click', function(e) {
        if (e.target === this) closeExportModal();
    });

    function openCompleteModal() {
        document.getElementById('completeModal').style.display = 'flex';
    }
    function closeCompleteModal() {
        document.getElementById('completeModal').style.display = 'none';
    }
    function toggleAllCompleteModules(cb) {
        document.querySelectorAll('.complete-module-cb').forEach(c => c.checked = cb.checked);
    }
    function updateCompleteSelectAll() {
        const all     = document.querySelectorAll('.complete-module-cb');
        const checked = document.querySelectorAll('.complete-module-cb:checked');
        document.getElementById('completeSelectAll').checked       = all.length === checked.length;
        document.getElementById('completeSelectAll').indeterminate = checked.length > 0 && checked.length < all.length;
    }
    function confirmComplete() {
        const selected = [...document.querySelectorAll('.complete-module-cb:checked')].map(c => c.value);
        if (selected.length === 0) { alert('Please select at least one module.'); return; }
        document.getElementById('completeForm').submit();
    }
    // Close complete modal on backdrop click
    document.getElementById('completeModal').addEventListener('click', function(e) {
        if (e.target === this) closeCompleteModal();
    });
</script>
</body>
</html>
