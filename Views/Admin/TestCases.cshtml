@model List<CloudsferQA.Models.TestCase>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Test Case Management";

    var savedOrder = ViewBag.ModuleOrder as Dictionary<string, int> ?? new Dictionary<string, int>();

    var submoduleOrder = ViewBag.ModuleOrder as Dictionary<string, int> ?? new();

    var grouped = Model
        .Where(t => !t.IsDeleted)
        .GroupBy(t => t.Module)
        .OrderBy(g => savedOrder.TryGetValue(g.Key, out var o) ? o : int.MaxValue)
        .ThenBy(g => g.Key)
        .ToDictionary(
            g => g.Key,
            g => g.GroupBy(t => t.Submodule)
                   .OrderBy(sg => submoduleOrder.TryGetValue(g.Key + "__" + sg.Key, out var so) ? so : int.MaxValue)
                   .ThenBy(sg => sg.Key)
                   .ToDictionary(
                sg => sg.Key,
                sg => sg.GroupBy(t => t.Group)
                        .OrderBy(gg => string.IsNullOrEmpty(gg.Key) ? "\xFF" : gg.Key)
                        .ToDictionary(gg => gg.Key, gg => gg.OrderBy(t => t.SortOrder).ThenBy(t => t.Id).ToList())
            )
        );
}

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 style="font-weight:700;color:#1565C0;margin:0">Test Case Management</h2>
            <div style="font-size:13px;color:#78909C;margin-top:2px">@Model.Count total test cases across @grouped.Count modules</div>
        </div>
        <a href="/Admin" style="font-size:13px;color:#546E7A;text-decoration:none">← Back to Admin</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div style="background:#E8F5E9;border:1px solid #A5D6A7;color:#2E7D32;padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px">
            ✓ @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div style="background:#FFEBEE;border:1px solid #EF9A9A;color:#C62828;padding:10px 16px;border-radius:8px;margin-bottom:16px;font-size:13px">
            ✗ @TempData["Error"]
        </div>
    }

    <!-- Add new module / Import buttons -->
    <div class="mb-3 d-flex gap-2">
        <button class="btn btn-sm btn-primary" onclick="showAddModule()">+ Add New Module</button>
        <button class="btn btn-sm btn-success" onclick="document.getElementById('importModal').style.display='flex'">↑ Import from File</button>
    </div>

    <!-- Import Modal -->
    <div id="importModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:center;justify-content:center">
        <div style="background:#fff;border-radius:12px;width:100%;max-width:500px;box-shadow:0 8px 40px rgba(0,0,0,.25);overflow:hidden">
            <!-- Header -->
            <div style="background:#2E7D32;padding:14px 20px;display:flex;align-items:center;justify-content:space-between">
                <span style="font-size:15px;font-weight:700;color:#fff">Import Test Cases</span>
                <button onclick="document.getElementById('importModal').style.display='none'" style="background:none;border:none;color:#fff;font-size:20px;line-height:1;cursor:pointer">×</button>
            </div>
            <!-- Body -->
            <div style="padding:20px">
                <div style="background:#E8F5E9;border:1px solid #A5D6A7;border-radius:8px;padding:12px 16px;font-size:12px;color:#2E7D32;margin-bottom:16px;line-height:1.7">
                    <strong>Supported formats:</strong> CSV (.csv) and Excel (.xlsx)<br>
                    <strong>Required columns:</strong> Module, Submodule, Scenario<br>
                    <strong>Optional columns:</strong> Steps, ExpectedResult, Priority (High/Medium/Low)<br>
                    Each row becomes one test case. Modules are created automatically.
                </div>
                <a href="/Admin/DownloadImportTemplate" style="font-size:12px;color:#1565C0;text-decoration:underline;display:inline-block;margin-bottom:16px">↓ Download sample template (CSV)</a>

                <form method="post" action="/Admin/ImportTestCases" enctype="multipart/form-data">
                    <div style="margin-bottom:16px">
                        <label style="font-size:12px;font-weight:600;color:#546E7A;display:block;margin-bottom:6px">SELECT FILE</label>
                        <input type="file" name="file" accept=".csv,.xlsx" required class="form-control form-control-sm">
                    </div>
                    <div style="display:flex;gap:8px;justify-content:flex-end">
                        <button type="button" onclick="document.getElementById('importModal').style.display='none'" class="btn btn-sm btn-secondary">Cancel</button>
                        <button type="submit" class="btn btn-sm btn-success">Import</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Add Module inline form (hidden by default) -->
    <div id="addModuleForm" style="display:none;background:#F8F9FA;border:1px solid #DEE2E6;border-radius:10px;margin-bottom:16px;overflow:hidden">

        <!-- Sticky header with title + action buttons -->
        <div style="position:sticky;top:0;z-index:10;background:#1565C0;padding:12px 20px;display:flex;align-items:center;justify-content:space-between">
            <span style="font-size:14px;font-weight:700;color:#fff">Add New Module</span>
            <div style="display:flex;gap:8px;align-items:center">
                <div id="addModuleStatus" style="font-size:12px;color:#FFCC80;display:none"></div>
                <button type="button" onclick="submitNewModule()" class="btn btn-sm btn-success" style="padding:4px 16px">Save Module</button>
                <button type="button" onclick="cancelAddModule()" class="btn btn-sm" style="background:rgba(255,255,255,.2);color:#fff;padding:4px 12px">Cancel</button>
            </div>
        </div>

        <div style="padding:20px">
            <!-- Module name -->
            <div style="margin-bottom:14px">
                <label style="font-size:12px;font-weight:600;color:#546E7A;display:block;margin-bottom:4px">MODULE NAME</label>
                <input id="newModuleName" placeholder="e.g. Registration &amp; Activation" class="form-control form-control-sm" style="max-width:320px" required>
            </div>

            <!-- Submodules list -->
            <div style="font-size:12px;font-weight:600;color:#546E7A;margin-bottom:8px">SUBMODULES</div>
            <div id="submoduleList"></div>

            <!-- Add submodule button -->
            <button type="button" onclick="addSubmoduleRow()" style="margin-top:6px;background:none;border:1px dashed #90A4AE;border-radius:6px;color:#546E7A;font-size:12px;padding:5px 14px;cursor:pointer;display:flex;align-items:center;gap:5px">
                <span style="font-size:16px;line-height:1">+</span> Add Submodule
            </button>
        </div>
    </div>

    <!-- Module accordion (drag to reorder) -->
    <div id="moduleList">
    @{ int modIdx = 0; }
    @foreach (var (moduleName, submodules) in grouped)
    {
        var moduleCount = submodules.Values.Sum(l => l.Count);
        var mId = modIdx++;
        <div class="tc-module mb-3" data-module="@moduleName" id="mod-@moduleName.GetHashCode()" style="border:1px solid #E0E0E0;border-radius:10px;overflow:hidden">

            <!-- Module header -->
            <div style="background:#1565C0;color:#fff;padding:12px 16px;display:flex;align-items:center;justify-content:space-between">
                <div style="display:flex;align-items:center;gap:12px">
                    <span class="drag-handle" title="Drag to reorder" style="cursor:grab;color:rgba(255,255,255,.6);font-size:16px;line-height:1;user-select:none">⠿</span>
                    <button onclick="toggleModule(this)" style="background:none;border:none;color:#fff;font-size:16px;cursor:pointer;padding:0;line-height:1">▸</button>
                    <strong style="font-size:14px">@moduleName</strong>
                    <span style="font-size:11px;background:rgba(255,255,255,.2);padding:2px 8px;border-radius:10px">@moduleCount test cases</span>
                </div>
                <div style="display:flex;gap:6px">
                    <button class="tc-btn tc-btn-light" onclick="toggleRename('rename-mod-@mId')">Rename</button>
                    <a href="/Admin/AddTestCase?moduleName=@Uri.EscapeDataString(moduleName)&submoduleName=" class="tc-btn tc-btn-light">+ Submodule</a>
                    <form method="post" action="/Admin/DeleteModule" style="margin:0"
                          onsubmit="return confirmDeleteModule(this, '@moduleName')">
                        <input type="hidden" name="moduleName" value="@moduleName">
                        <input type="hidden" name="pin" value="">
                        <button type="submit" class="tc-btn tc-btn-danger">Delete Module</button>
                    </form>
                </div>
            </div>

            <!-- Rename module inline form -->
            <div id="rename-mod-@mId" style="display:none;background:#FFF8E1;padding:10px 16px;border-bottom:1px solid #FFE082">
                <form method="post" action="/Admin/RenameModule" style="display:flex;gap:8px;align-items:center">
                    <input type="hidden" name="oldName" value="@moduleName">
                    <input name="newName" value="@moduleName" class="form-control form-control-sm" style="max-width:280px" required>
                    <button type="submit" class="btn btn-sm btn-warning">Save</button>
                    <button type="button" class="btn btn-sm btn-secondary" onclick="toggleRename('rename-mod-@mId')">Cancel</button>
                </form>
            </div>

            <!-- Submodules — collapsed by default -->
            <div class="tc-module-body" style="display:none">
                <div class="submodule-list" data-module="@moduleName">
                @{ int subIdx = 0; }
                @foreach (var (submoduleName, groups) in submodules)
                {
                    var sId = $"s{mId}_{subIdx++}";
                    var subTotal = groups.Values.Sum(l => l.Count);
                    bool hasGroups = groups.Any(g => !string.IsNullOrEmpty(g.Key));
                    <div style="border-bottom:1px solid #F5F5F5" data-submodule="@submoduleName">
                        <!-- Submodule header -->
                        <div style="background:#F9F9F9;padding:8px 16px 8px 16px;display:flex;align-items:center;justify-content:space-between">
                            <div style="display:flex;align-items:center;gap:10px">
                                <span class="sub-drag-handle" title="Drag to reorder" style="cursor:grab;color:#B0BEC5;font-size:15px;line-height:1;user-select:none">⠿</span>
                                <button onclick="toggleSubmodule(this)" style="background:none;border:none;color:#546E7A;font-size:13px;cursor:pointer;padding:0">▸</button>
                                <span style="font-weight:600;color:#37474F;font-size:13px">@submoduleName</span>
                                <span style="font-size:11px;color:#90A4AE">@subTotal cases</span>
                            </div>
                            <div style="display:flex;gap:6px">
                                <button class="tc-btn tc-btn-muted" onclick="toggleRename('rename-sub-@sId')">Rename</button>
                                <a href="/Admin/AddTestCase?moduleName=@Uri.EscapeDataString(moduleName)&submoduleName=@Uri.EscapeDataString(submoduleName)" class="tc-btn tc-btn-muted">+ Test Case</a>
                                <form method="post" action="/Admin/DeleteSubmodule" style="margin:0"
                                      onsubmit="return confirm('Delete this submodule and all its test cases?')">
                                    <input type="hidden" name="moduleName" value="@moduleName">
                                    <input type="hidden" name="submoduleName" value="@submoduleName">
                                    <button type="submit" class="tc-btn tc-btn-danger">Delete</button>
                                </form>
                            </div>
                        </div>

                        <!-- Rename submodule inline form -->
                        <div id="rename-sub-@sId" style="display:none;background:#FFF8E1;padding:8px 16px 8px 32px;border-top:1px solid #FFE082">
                            <form method="post" action="/Admin/RenameSubmodule" style="display:flex;gap:8px;align-items:center">
                                <input type="hidden" name="moduleName" value="@moduleName">
                                <input type="hidden" name="oldName" value="@submoduleName">
                                <input name="newName" value="@submoduleName" class="form-control form-control-sm" style="max-width:280px" required>
                                <button type="submit" class="btn btn-sm btn-warning">Save</button>
                                <button type="button" class="btn btn-sm btn-secondary" onclick="toggleRename('rename-sub-@sId')">Cancel</button>
                            </form>
                        </div>

                        <!-- Groups + Test cases — collapsed by default -->
                        <div class="tc-sub-body" style="display:none">
                            @foreach (var (groupName, cases) in groups)
                            {
                                @if (hasGroups && !string.IsNullOrEmpty(groupName))
                                {
                                    <!-- Group header -->
                                    <div style="background:#F0F4FF;padding:6px 16px 6px 52px;border-top:1px solid #E8EAF6;display:flex;align-items:center;gap:8px">
                                        <span style="color:#3949AB;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px">@groupName</span>
                                        <span style="font-size:10px;color:#9FA8DA">@cases.Count cases</span>
                                    </div>
                                }
                                <table style="width:100%;font-size:12px;border-collapse:collapse">
                                    <thead>
                                        <tr style="background:#FAFAFA;color:#90A4AE;text-transform:uppercase;font-size:10px;letter-spacing:.5px">
                                            <th style="padding:6px 8px;width:20px"></th>
                                            <th style="padding:6px 8px;text-align:left">ID</th>
                                            <th style="padding:6px 8px;text-align:left">Scenario</th>
                                            <th style="padding:6px 8px;text-align:left">Priority</th>
                                            <th style="padding:6px 16px;text-align:right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="tc-sortable-body" data-module="@moduleName" data-submodule="@submoduleName">
                                        @foreach (var tc in cases)
                                        {
                                            <tr style="border-top:1px solid #F5F5F5" data-id="@tc.Id">
                                                <td style="padding:8px;color:#B0BEC5;cursor:grab;user-select:none;font-size:14px" class="tc-drag-handle">⠿</td>
                                                <td style="padding:8px;color:#1565C0;font-weight:600;white-space:nowrap">@tc.Id</td>
                                                <td style="padding:8px;color:#37474F">@tc.Scenario</td>
                                                <td style="padding:8px">
                                                    <span style="font-size:10px;padding:2px 7px;border-radius:8px;font-weight:600;
                                                        background:@(tc.Priority=="High"?"#FFEBEE":tc.Priority=="Medium"?"#FFF3E0":"#E8F5E9");
                                                        color:@(tc.Priority=="High"?"#C62828":tc.Priority=="Medium"?"#E65100":"#2E7D32")">
                                                        @tc.Priority
                                                    </span>
                                                </td>
                                                <td style="padding:8px 16px;text-align:right;white-space:nowrap">
                                                    <a href="/Admin/EditTestCase/@tc.Id" class="tc-btn tc-btn-muted">Edit</a>
                                                    <form method="post" action="/Admin/DeleteTestCase" style="display:inline;margin:0"
                                                          onsubmit="return confirm('Delete test case @tc.Id?')">
                                                        <input type="hidden" name="id" value="@tc.Id">
                                                        <button type="submit" class="tc-btn tc-btn-danger">Delete</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                }
                </div><!-- end submodule-list -->
            </div>
        </div>
    }
    </div>

    <!-- ── Bin Section ────────────────────────────────────────────────── -->
    @{
        var deletedGrouped = Model.Where(t => t.IsDeleted)
            .GroupBy(t => t.Module)
            .OrderBy(g => g.Key)
            .ToList();
    }
    <div style="margin-top:32px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
            <div style="display:flex;align-items:center;gap:10px">
                <span style="font-size:18px">🗑</span>
                <span style="font-size:15px;font-weight:700;color:#546E7A">Bin</span>
                <span style="font-size:11px;background:#ECEFF1;color:#78909C;padding:2px 8px;border-radius:10px">@deletedGrouped.Count module(s)</span>
            </div>
            @if (deletedGrouped.Any())
            {
                <form method="post" action="/Admin/EmptyBin" onsubmit="return confirm('Permanently delete everything in the Bin? This cannot be undone.')">
                    <button type="submit" style="font-size:11px;background:#FFEBEE;color:#C62828;border:1px solid #FFCDD2;border-radius:5px;padding:3px 12px;cursor:pointer;font-weight:600">Empty Bin</button>
                </form>
            }
        </div>

        @if (!deletedGrouped.Any())
        {
            <div style="background:#FAFAFA;border:1px dashed #CFD8DC;border-radius:10px;padding:24px;text-align:center;color:#90A4AE;font-size:13px">
                Bin is empty — deleted modules will appear here
            </div>
        }
        else
        {
            <!-- Deleted Items folder (wraps all modules) -->
            <div style="border:1px solid #CFD8DC;border-radius:10px;overflow:hidden">
                <div id="deleted-items-header"
                     style="background:#ECEFF1;padding:11px 16px;display:flex;align-items:center;gap:10px;cursor:pointer;user-select:none"
                     onclick="toggleDeletedItems()">
                    <span id="deleted-items-icon" style="font-size:13px;color:#90A4AE;transition:transform .2s;display:inline-block">▶</span>
                    <span style="font-size:14px">📁</span>
                    <span style="font-size:13px;font-weight:700;color:#546E7A">Deleted Items</span>
                    <span style="font-size:11px;background:#CFD8DC;color:#546E7A;padding:2px 8px;border-radius:10px">@deletedGrouped.Count module(s)</span>
                </div>
                <div id="deleted-items-panel" style="display:none;padding:10px 12px;background:#FAFAFA">
                    @{var binIdx = 0;}
                    @foreach (var binModule in deletedGrouped)
                    {
                        var binCount    = binModule.Count();
                        var deletedTime = binModule.Max(t => t.DeletedAt);
                        var panelId     = $"bin-panel-{binIdx++}";
                        <div style="border:1px solid #ECEFF1;border-radius:8px;overflow:hidden;margin-bottom:8px;opacity:0.92">
                            <!-- Module header row -->
                            <div class="bin-module-header" data-target="@panelId"
                                 style="background:#F5F5F5;padding:9px 14px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none">
                                <div style="display:flex;align-items:center;gap:10px">
                                    <span class="bin-toggle-icon" style="font-size:12px;color:#90A4AE;transition:transform .2s;display:inline-block">▶</span>
                                    <span style="font-size:13px">📂</span>
                                    <span style="font-size:13px;font-weight:600;color:#546E7A">@binModule.Key</span>
                                    <span style="font-size:11px;background:#CFD8DC;color:#546E7A;padding:2px 8px;border-radius:10px">@binCount test case(s)</span>
                                    @if (deletedTime.HasValue)
                                    {
                                        <span style="font-size:11px;color:#90A4AE">Deleted @deletedTime.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                                    }
                                </div>
                                <div style="display:flex;gap:6px;align-items:center" onclick="event.stopPropagation()">
                                    <form method="post" action="/Admin/RestoreModule" style="margin:0"
                                          onsubmit="return validateRestorePin(this)">
                                        <input type="hidden" name="moduleName" value="@binModule.Key">
                                        <input type="hidden" name="pin" value="">
                                        <button type="submit" style="font-size:11px;background:#E8F5E9;color:#2E7D32;border:1px solid #A5D6A7;border-radius:5px;padding:3px 12px;cursor:pointer;font-weight:600">Restore</button>
                                    </form>
                                    <form method="post" action="/Admin/PermanentDeleteModule" style="margin:0"
                                          onsubmit="return confirmPermanentDelete(this, '@binModule.Key')">
                                        <input type="hidden" name="moduleName" value="@binModule.Key">
                                        <input type="hidden" name="pin" value="">
                                        <button type="submit" style="font-size:11px;background:#FFEBEE;color:#C62828;border:1px solid #FFCDD2;border-radius:5px;padding:3px 12px;cursor:pointer;font-weight:600">Delete Forever</button>
                                    </form>
                                </div>
                            </div>
                            <!-- Collapsible test cases -->
                            <div id="@panelId" style="display:none;background:#FAFAFA">
                                @foreach (var sub in binModule.GroupBy(t => t.Submodule).OrderBy(g => g.Key))
                                {
                                    <div style="border-top:1px solid #ECEFF1;padding:8px 16px 8px 44px">
                                        <div style="font-size:12px;font-weight:700;color:#78909C;margin-bottom:4px">@sub.Key</div>
                                        @foreach (var tc in sub.OrderBy(t => t.Id))
                                        {
                                            <div style="display:flex;align-items:center;gap:8px;padding:3px 0;border-bottom:1px solid #F5F5F5">
                                                <span style="font-size:11px;color:#1565C0;font-weight:600;min-width:70px">@tc.Id</span>
                                                <span style="font-size:12px;color:#546E7A;flex:1">@tc.Scenario</span>
                                                <span style="font-size:10px;padding:1px 7px;border-radius:8px;font-weight:600;
                                                    background:@(tc.Priority=="High"?"#FFEBEE":tc.Priority=="Medium"?"#FFF3E0":"#E8F5E9");
                                                    color:@(tc.Priority=="High"?"#C62828":tc.Priority=="Medium"?"#E65100":"#2E7D32")">
                                                    @tc.Priority
                                                </span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

</div>

<style>
    .tc-btn { display:inline-block;padding:3px 10px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;border:none;text-decoration:none;font-family:inherit }
    .tc-btn-light  { background:rgba(255,255,255,.2);color:#fff }
    .tc-btn-light:hover { background:rgba(255,255,255,.35);color:#fff }
    .tc-btn-muted  { background:#ECEFF1;color:#546E7A }
    .tc-btn-muted:hover { background:#CFD8DC;color:#37474F }
    .tc-btn-danger { background:#FFEBEE;color:#C62828 }
    .tc-btn-danger:hover { background:#FFCDD2 }
</style>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
    // Bin — Deleted Items folder toggle
    function toggleDeletedItems() {
        var panel = document.getElementById('deleted-items-panel');
        var icon  = document.getElementById('deleted-items-icon');
        var open  = panel.style.display === 'block';
        panel.style.display = open ? 'none' : 'block';
        icon.style.transform = open ? 'rotate(0deg)' : 'rotate(90deg)';
    }

    // Bin — module expand/collapse
    document.querySelectorAll('.bin-module-header').forEach(function(header) {
        header.addEventListener('click', function() {
            var panelId = this.getAttribute('data-target');
            var panel   = document.getElementById(panelId);
            var icon    = this.querySelector('.bin-toggle-icon');
            var open    = panel.style.display === 'block';
            panel.style.display = open ? 'none' : 'block';
            icon.style.transform = open ? 'rotate(0deg)' : 'rotate(90deg)';
        });
    });

    // Delete Module (to Bin) — PIN prompt
    function confirmDeleteModule(form, moduleName) {
        if (!confirm('Move module "' + moduleName + '" and all its test cases to Bin?')) return false;
        var pin = prompt('Enter your admin PIN to confirm:');
        if (pin === null) return false;
        if (!pin.trim()) { alert('PIN is required.'); return false; }
        form.querySelector('input[name="pin"]').value = pin.trim();
        return true;
    }

    // Bin — PIN before permanent delete
    function confirmPermanentDelete(form, moduleName) {
        if (!confirm('Permanently delete module "' + moduleName + '" and all its test cases? This cannot be undone.')) return false;
        var pin = prompt('Enter your admin PIN to confirm permanent deletion:');
        if (pin === null) return false;
        if (!pin.trim()) { alert('PIN is required.'); return false; }
        form.querySelector('input[name="pin"]').value = pin.trim();
        return true;
    }

    // Bin — validate PIN before restore
    function validateRestorePin(form) {
        var pin = prompt('Enter your admin PIN to restore this module:');
        if (pin === null) return false;
        if (!pin.trim()) { alert('PIN is required.'); return false; }
        form.querySelector('input[name="pin"]').value = pin.trim();
        return true;
    }

    // Drag-and-drop module reordering
    Sortable.create(document.getElementById('moduleList'), {
        handle: '.drag-handle',
        animation: 150,
        onEnd: function () {
            const order = [...document.querySelectorAll('#moduleList .tc-module')]
                .map(el => el.dataset.module);
            fetch('/Admin/SaveModuleOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(order)
            });
        }
    });

    // Drag-and-drop submodule reordering within each module
    document.querySelectorAll('.submodule-list').forEach(list => {
        Sortable.create(list, {
            handle: '.sub-drag-handle',
            animation: 150,
            onEnd: function () {
                const module = list.dataset.module;
                const submodules = [...list.children]
                    .filter(el => el.dataset.submodule)
                    .map(el => el.dataset.submodule);
                fetch('/Admin/SaveSubmoduleOrder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ module, submodules })
                });
            }
        });
    });

    // Drag-and-drop test case reordering within each submodule
    document.querySelectorAll('.tc-sortable-body').forEach(tbody => {
        Sortable.create(tbody, {
            handle: '.tc-drag-handle',
            animation: 150,
            onEnd: function () {
                const module    = tbody.dataset.module;
                const submodule = tbody.dataset.submodule;
                const ids       = [...tbody.querySelectorAll('tr[data-id]')].map(r => r.dataset.id);
                fetch('/Admin/SaveTestCaseOrder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ module, submodule, ids })
                });
            }
        });
    });

    function toggleRename(id) {
        const el = document.getElementById(id);
        if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
    }
    function toggleModule(btn) {
        const body = btn.closest('.tc-module').querySelector('.tc-module-body');
        const open = body.style.display !== 'none';
        body.style.display = open ? 'none' : '';
        btn.textContent = open ? '▸' : '▾';
    }
    function toggleSubmodule(btn) {
        const subBody = btn.closest('div').parentElement.nextElementSibling.nextElementSibling;
        const open = subBody.style.display !== 'none';
        subBody.style.display = open ? 'none' : '';
        btn.textContent = open ? '▸' : '▾';
    }
    function showAddModule() {
        const f = document.getElementById('addModuleForm');
        if (f.style.display === 'none' || f.style.display === '') {
            f.style.display = 'block';
            document.getElementById('newModuleName').value = '';
            document.getElementById('submoduleList').innerHTML = '';
            document.getElementById('addModuleStatus').style.display = 'none';
            addSubmoduleRow(); // start with one row
        } else {
            f.style.display = 'none';
        }
    }

    function addSubmoduleRow() {
        const list = document.getElementById('submoduleList');
        const idx = list.children.length + 1;
        const row = document.createElement('div');
        row.className = 'submodule-row';
        row.style.cssText = 'background:#fff;border:1px solid #E0E0E0;border-radius:8px;padding:12px 14px;margin-bottom:8px';
        row.innerHTML = `
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                <span style="font-size:12px;font-weight:600;color:#37474F">Submodule ${idx}</span>
                <button type="button" onclick="removeSubmoduleRow(this)" style="background:none;border:none;color:#EF5350;font-size:18px;line-height:1;cursor:pointer;padding:0" title="Remove">×</button>
            </div>
            <div style="margin-bottom:10px">
                <label style="font-size:11px;color:#90A4AE;display:block;margin-bottom:3px">Submodule Name</label>
                <input class="form-control form-control-sm sub-name" placeholder="e.g. Account Registration" style="max-width:280px" required>
            </div>
            <div>
                <label style="font-size:11px;color:#90A4AE;display:block;margin-bottom:6px">Scenarios</label>
                <div class="scenario-list"></div>
                <button type="button" onclick="addScenarioRow(this)" style="margin-top:5px;background:none;border:1px dashed #B0BEC5;border-radius:5px;color:#78909C;font-size:11px;padding:3px 10px;cursor:pointer">+ Add Scenario</button>
            </div>`;
        list.appendChild(row);
        renumberRows();
        // auto-add first scenario row
        addScenarioRow(row.querySelector('button[onclick^="addScenario"]'));
    }

    function addScenarioRow(btn) {
        const scenarioList = btn.previousElementSibling;
        const sIdx = scenarioList.children.length + 1;
        const sRow = document.createElement('div');
        sRow.className = 'scenario-row';
        sRow.style.cssText = 'display:flex;gap:8px;align-items:center;margin-bottom:6px';
        sRow.innerHTML = `
            <span style="font-size:11px;color:#B0BEC5;min-width:14px">${sIdx}.</span>
            <input class="form-control form-control-sm sc-scenario" placeholder="e.g. Verify user can register with valid email" required style="flex:1">
            <select class="form-select form-select-sm sc-priority" style="width:100px">
                <option>High</option><option selected>Medium</option><option>Low</option>
            </select>
            <button type="button" onclick="removeScenarioRow(this)" style="background:none;border:none;color:#EF5350;font-size:16px;line-height:1;cursor:pointer;padding:0;flex-shrink:0" title="Remove">×</button>`;
        scenarioList.appendChild(sRow);
        renumberScenarios(scenarioList);
    }

    function removeScenarioRow(btn) {
        const scenarioList = btn.closest('.scenario-row').parentElement;
        btn.closest('.scenario-row').remove();
        renumberScenarios(scenarioList);
    }

    function renumberScenarios(list) {
        list.querySelectorAll('.scenario-row').forEach((row, i) => {
            row.querySelector('span').textContent = `${i + 1}.`;
        });
    }

    function removeSubmoduleRow(btn) {
        btn.closest('.submodule-row').remove();
        renumberRows();
    }

    function renumberRows() {
        document.querySelectorAll('#submoduleList .submodule-row').forEach((row, i) => {
            row.querySelector('span').textContent = `Submodule ${i + 1}`;
        });
    }

    function cancelAddModule() {
        document.getElementById('addModuleForm').style.display = 'none';
    }

    async function submitNewModule() {
        const moduleName = document.getElementById('newModuleName').value.trim();
        const status = document.getElementById('addModuleStatus');
        if (!moduleName) { status.style.display='block'; status.textContent='Please enter a module name.'; return; }

        const subRows = document.querySelectorAll('#submoduleList .submodule-row');
        if (subRows.length === 0) { status.style.display='block'; status.textContent='Please add at least one submodule.'; return; }

        // collect all entries: { sub, scenario, priority }
        const entries = [];
        for (const row of subRows) {
            const sub = row.querySelector('.sub-name').value.trim();
            if (!sub) { status.style.display='block'; status.textContent='Please fill in all submodule names.'; return; }
            const scenarioRows = row.querySelectorAll('.scenario-row');
            if (scenarioRows.length === 0) { status.style.display='block'; status.textContent=`Please add at least one scenario for "${sub}".`; return; }
            for (const sr of scenarioRows) {
                const scenario = sr.querySelector('.sc-scenario').value.trim();
                const priority = sr.querySelector('.sc-priority').value;
                if (!scenario) { status.style.display='block'; status.textContent=`Please fill in all scenarios for "${sub}".`; return; }
                entries.push({ sub, scenario, priority });
            }
        }

        status.style.display = 'none';
        const btn = document.querySelector('#addModuleForm .btn-success');
        btn.disabled = true; btn.textContent = 'Adding...';

        for (const e of entries) {
            const fd = new FormData();
            fd.append('Module', moduleName);
            fd.append('Submodule', e.sub);
            fd.append('Scenario', e.scenario);
            fd.append('Priority', e.priority);
            fd.append('Steps', '');
            fd.append('ExpectedResult', '');
            await fetch('/Admin/AddTestCase', { method: 'POST', body: fd });
        }

        window.location.reload();
    }

    // Auto-expand and scroll to module after save
    @if (TempData["ScrollTo"] != null)
    {
        <text>
    (function() {
        const target = '@TempData["ScrollTo"]';
        const mod = [...document.querySelectorAll('.tc-module')]
            .find(el => el.dataset.module === target);
        if (!mod) return;
        const body = mod.querySelector('.tc-module-body');
        const btn  = mod.querySelector('.module-header button');
        if (body) body.style.display = '';
        if (btn)  btn.textContent = '▾';
        setTimeout(() => mod.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
    })();
        </text>
    }
</script>
}
