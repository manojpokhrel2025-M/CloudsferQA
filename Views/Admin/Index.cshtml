@model CloudsferQA.Models.ViewModels.AdminUsersViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
    var userStats = ViewBag.UserStats as Dictionary<int, dynamic> ?? new();
}

<!-- Hero -->
<div class="dash-hero">
    <div class="dash-hero-inner">
        <img src="/images/logo.svg" alt="Cloudsfer" height="34" class="dash-logo">
        <div>
            <h1 class="dash-title">User Management</h1>
            <p class="dash-subtitle">Manage team access to CloudsferQA</p>
        </div>
        <div style="display:flex;gap:8px">
            <a href="/Admin/TestCases" style="background:#fff;color:#1565C0;padding:8px 18px;border-radius:8px;font-weight:600;font-size:13px;text-decoration:none">
                📋 Manage Test Cases
            </a>
            <a href="/Admin/ActivityLog" style="background:rgba(255,255,255,.2);color:#fff;padding:8px 18px;border-radius:8px;font-weight:600;font-size:13px;text-decoration:none">
                📜 Activity Log
            </a>
        </div>
    </div>
</div>

<div class="container-fluid px-4 py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats strip -->
    <div class="row g-3 mb-4">
        @{
            int total    = Model.Users.Count;
            int verified = Model.Users.Count(u => u.IsEmailVerified);
            int pending  = total - verified;
            int admins   = Model.Users.Count(u => u.Role == "Admin");
            int active   = Model.Users.Count(u => u.IsActive);
        }
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-total"><div class="kpi-label">Total Users</div><div class="kpi-value">@total</div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-pass"><div class="kpi-label">Verified</div><div class="kpi-value">@verified</div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-pending"><div class="kpi-label">Pending</div><div class="kpi-value">@pending</div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card kpi-blocked"><div class="kpi-label">Admins</div><div class="kpi-value">@admins</div></div>
        </div>
    </div>

    <!-- Danger Zone: Reset / Restore Sessions -->
    <div style="background:#FFF8F8;border:1px solid #FFCDD2;border-radius:10px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
        <div>
            <div style="font-weight:700;color:#C62828;font-size:14px">⚡ Session Management</div>
            <div style="font-size:12px;color:#78909C;margin-top:2px">Reset archives all active sessions (backup kept). Restore brings them back. Both require PIN.</div>
        </div>
        <div style="display:flex;gap:8px">
            <button type="button" onclick="openPinModal('restore')"
                    style="background:#1565C0;color:#fff;border:none;border-radius:7px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">
                ↩ Restore from Backup
            </button>
            <button type="button" onclick="openPinModal('reset')"
                    style="background:#C62828;color:#fff;border:none;border-radius:7px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">
                🗑 Reset All Sessions
            </button>
        </div>
    </div>

    <!-- PIN Modal (shared for Reset and Restore) -->
    <div id="resetPinModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
        <div style="background:#fff;border-radius:12px;width:380px;max-width:95vw;box-shadow:0 8px 32px rgba(0,0,0,.25);overflow:hidden">
            <!-- Header (color set by JS) -->
            <div id="pinModalHeader" style="background:#C62828;padding:14px 20px;display:flex;align-items:center;justify-content:space-between">
                <span id="pinModalTitle" style="color:#fff;font-weight:700;font-size:14px">🔒 Enter PIN</span>
                <button onclick="closeResetModal()" style="background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1;padding:0">×</button>
            </div>
            <!-- Body -->
            <form id="pinModalForm" method="post" action="/Admin/ResetAllSessions" onsubmit="return validatePin()">
                <div style="padding:24px 20px">
                    <div id="pinModalDesc" style="font-size:13px;color:#546E7A;margin-bottom:16px;line-height:1.6"></div>
                    <div style="margin-bottom:8px">
                        <label style="font-size:11px;font-weight:600;color:#546E7A;display:block;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px">Admin PIN</label>
                        <input type="password" id="resetPinInput" name="pin" maxlength="10"
                               placeholder="● ● ● ●"
                               style="width:100%;padding:10px 14px;border:2px solid #E0E0E0;border-radius:8px;font-size:22px;letter-spacing:8px;text-align:center;font-family:inherit;outline:none;box-sizing:border-box"
                               autocomplete="off">
                        <div id="resetPinError" style="color:#C62828;font-size:12px;margin-top:6px;display:none">Please enter the PIN.</div>
                    </div>
                </div>
                <div style="padding:12px 20px;border-top:1px solid #F0F0F0;display:flex;gap:8px;justify-content:flex-end">
                    <button type="button" onclick="closeResetModal()" style="background:#ECEFF1;border:none;border-radius:6px;padding:8px 18px;font-size:13px;color:#546E7A;cursor:pointer;font-weight:600;font-family:inherit">Cancel</button>
                    <button id="pinModalConfirmBtn" type="submit" style="background:#C62828;border:none;border-radius:6px;padding:8px 20px;font-size:13px;color:#fff;cursor:pointer;font-weight:700;font-family:inherit">Confirm</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Template Downloads -->
    <div class="dash-card mb-4">
        <div class="dash-card-title">📥 Module Test Case Templates</div>
        <p style="font-size:12px;color:#78909C;margin:6px 0 16px">Download pre-built CSV templates for each module. Fill them in and import via Test Cases → Import.</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px">
            @{
                var templates = new[]
                {
                    ("01_Migration.csv",              "Migration"),
                    ("02_Backup.csv",                 "Backup"),
                    ("03_Restore.csv",                "Restore"),
                    ("04_Emails_Notifications.csv",   "Emails & Notifications"),
                    ("05_Registration_Onboarding.csv","Registration & Onboarding"),
                    ("06_OPA_OnPremise_Agent.csv",    "OPA (On-Premise Agent)"),
                    ("07_TaskBar.csv",                "Task Bar"),
                    ("08_Administrator.csv",          "Administrator"),
                    ("09_QA_Dev.csv",                 "QA & Dev"),
                    ("10_Pre_Validation.csv",         "Pre-Validation"),
                    ("11_CF_Grid_Auto_Refresh.csv",   "CF Grid Auto Refresh"),
                    ("12_Report_AdminReport.csv",     "Report – Admin Report"),
                    ("13_Report_ClientReport.csv",    "Report – Client Report"),
                };
            }
            @foreach (var (file, label) in templates)
            {
                <a href="/Admin/DownloadTemplate?file=@file" download
                   style="display:flex;align-items:center;gap:10px;background:#F8FAFE;border:1px solid #E3ECF8;border-radius:8px;padding:10px 14px;text-decoration:none;color:#1565C0;font-size:13px;font-weight:600;transition:background .15s"
                   onmouseover="this.style.background='#E3ECF8'" onmouseout="this.style.background='#F8FAFE'">
                    <span style="font-size:18px">📄</span>
                    <span>@label</span>
                </a>
            }
        </div>
        <div style="margin-top:14px">
            <a href="/Admin/DownloadAllTemplates"
               style="display:inline-flex;align-items:center;gap:8px;background:#1565C0;color:#fff;border-radius:8px;padding:9px 22px;font-size:13px;font-weight:700;text-decoration:none">
                ⬇ Download All as ZIP
            </a>
        </div>
    </div>

    <!-- Add User -->
    <div class="dash-card mb-4">
        <div class="dash-card-title">Add User to Directory</div>
        <form method="post" action="/Admin/AddUser" style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap;margin-top:12px">
            <div>
                <label style="font-size:12px;font-weight:600;color:#546E7A;display:block;margin-bottom:4px">EMAIL</label>
                <input name="email" type="email" placeholder="user@tzunami.com" required
                       class="sidebar-search" style="width:260px;padding:8px 12px">
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#546E7A;display:block;margin-bottom:4px">ROLE</label>
                <select name="role" class="sidebar-search" style="padding:8px 12px;width:130px">
                    <option value="QA">QA</option>
                    <option value="Dev">Dev</option>
                    <option value="SubAdmin">SubAdmin</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm" style="height:38px;padding:0 20px">+ Add User</button>
        </form>
    </div>

    <!-- Bulk Import Users -->
    <div class="dash-card mb-4">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <div class="dash-card-title mb-0">Bulk Import Users</div>
                <div style="font-size:12px;color:#78909C;margin-top:3px">Upload an Excel or CSV file to add many users at once. Existing emails are skipped.</div>
            </div>
            <a href="/Admin/DownloadUserImportTemplate"
               style="display:inline-flex;align-items:center;gap:6px;background:#E3F2FD;color:#1565C0;border-radius:7px;padding:8px 16px;font-size:12px;font-weight:700;text-decoration:none;white-space:nowrap">
                📥 Download Template
            </a>
        </div>

        <form method="post" action="/Admin/ImportUsers" enctype="multipart/form-data"
              style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <label id="userFileLabel"
                   style="display:flex;align-items:center;gap:8px;background:#F8FAFE;border:2px dashed #90CAF9;border-radius:8px;padding:10px 18px;cursor:pointer;font-size:13px;color:#546E7A;transition:border-color .2s"
                   onmouseover="this.style.borderColor='#1565C0'" onmouseout="this.style.borderColor='#90CAF9'">
                <span style="font-size:20px">📂</span>
                <span id="userFileName">Choose Excel / CSV file…</span>
                <input type="file" name="file" accept=".xlsx,.csv" required style="display:none"
                       onchange="document.getElementById('userFileName').textContent = this.files[0]?.name || 'Choose file…'">
            </label>
            <button type="submit" class="btn btn-primary btn-sm" style="height:38px;padding:0 22px;font-size:13px">
                ⬆ Import Users
            </button>
        </form>

        <div style="margin-top:10px;font-size:11px;color:#90A4AE">
            Template columns: <strong>Email</strong>, <strong>Role</strong> (QA / Dev / SubAdmin / Admin)
        </div>
    </div>

    <!-- Users table -->
    <div class="dash-card">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="dash-card-title mb-0">All Users</div>
            <input type="text" id="userSearch" class="sidebar-search" placeholder="Filter by email…"
                   style="width:240px;padding:7px 12px">
        </div>

        <div class="table-responsive">
            <table class="module-table" id="usersTable">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th class="text-center">Role</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Active</th>
                        <th class="text-center">Sessions</th>
                        <th class="text-center">Joined</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        var sc = Model.SessionCounts.TryGetValue(user.Id, out var c) ? c : 0;
                        <tr data-email="@user.Email">
                            <td>
                                <div style="font-weight:600;color:#212529">@user.Email</div>
                                @if (user.Id == Model.CurrentAdmin.Id)
                                {
                                    <span style="font-size:10px;color:#1565C0;font-weight:700">YOU</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="admin-role-badge role-@(user.Role.ToLower())">@user.Role</span>
                            </td>
                            <td class="text-center">
                                @if (user.IsEmailVerified)
                                {
                                    <span class="status-pill pill-done">✓ Registered</span>
                                }
                                else
                                {
                                    <span class="status-pill pill-not-started">📩 Invited</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (user.IsActive)
                                {
                                    <span class="status-pill pill-in-progress">Active</span>
                                }
                                else
                                {
                                    <span class="status-pill" style="background:#FFEBEE;color:#C62828">Disabled</span>
                                }
                            </td>
                            <td class="text-center">@sc</td>
                            <td class="text-center" style="font-size:12px;color:#90A4AE">
                                @user.CreatedAt.ToString("yyyy-MM-dd")
                            </td>
                            <td class="text-center" style="white-space:nowrap;min-width:220px">
                                <div style="display:flex;gap:6px;justify-content:center;align-items:center">
                                    <a href="/Admin/UserDetail/@user.Id" class="admin-btn admin-btn-view" style="min-width:52px;text-align:center">View</a>

                                    @if (!user.IsEmailVerified)
                                    {
                                        <form method="post" action="/Admin/VerifyUser" style="display:inline;margin:0">
                                            <input type="hidden" name="userId" value="@user.Id">
                                            <button type="submit" class="admin-btn admin-btn-verify" style="min-width:52px">Verify</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span style="min-width:52px;display:inline-block"></span>
                                    }

                                    @if (user.Id != Model.CurrentAdmin.Id)
                                    {
                                        <form method="post" action="/Admin/ToggleActive" style="display:inline;margin:0">
                                            <input type="hidden" name="userId" value="@user.Id">
                                            <button type="submit"
                                                    class="admin-btn @(user.IsActive ? "admin-btn-deactivate" : "admin-btn-activate")"
                                                    style="min-width:78px"
                                                    onclick="return confirm('@(user.IsActive ? "Deactivate" : "Activate") @user.Email?')">
                                                @(user.IsActive ? "Deactivate" : "Activate")
                                            </button>
                                        </form>
                                        <form method="post" action="/Admin/DeleteUser" style="display:inline;margin:0"
                                              onsubmit="return confirm('Permanently delete @user.Email? This cannot be undone.')">
                                            <input type="hidden" name="userId" value="@user.Id">
                                            <button type="submit" class="admin-btn" style="min-width:52px;background:#C62828;color:#fff;border-color:#C62828">Delete</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('userSearch').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#usersTable tbody tr').forEach(row => {
                row.style.display = (row.dataset.email || '').includes(q) ? '' : 'none';
            });
        });

        function openPinModal(mode) {
            const isReset = mode === 'reset';
            document.getElementById('pinModalHeader').style.background    = isReset ? '#C62828' : '#1565C0';
            document.getElementById('pinModalTitle').textContent          = isReset ? '🔒 PIN Required — Reset Sessions' : '🔒 PIN Required — Restore Sessions';
            document.getElementById('pinModalDesc').innerHTML             = isReset
                ? 'All active sessions will be <strong>archived</strong>. They are kept as backup and can be restored anytime.'
                : 'All archived sessions will be <strong>restored</strong> and become active again.';
            document.getElementById('pinModalConfirmBtn').style.background = isReset ? '#C62828' : '#1565C0';
            document.getElementById('pinModalConfirmBtn').textContent     = isReset ? '🗑 Archive Sessions' : '↩ Restore Sessions';
            document.getElementById('pinModalForm').action                = isReset ? '/Admin/ResetAllSessions' : '/Admin/RestoreArchivedSessions';
            document.getElementById('resetPinModal').style.display        = 'flex';
            setTimeout(() => document.getElementById('resetPinInput').focus(), 100);
        }
        function closeResetModal() {
            document.getElementById('resetPinModal').style.display = 'none';
            document.getElementById('resetPinInput').value = '';
            document.getElementById('resetPinError').style.display = 'none';
        }
        function validatePin() {
            const pin = document.getElementById('resetPinInput').value.trim();
            if (!pin) {
                document.getElementById('resetPinError').style.display = 'block';
                return false;
            }
            return true;
        }
        document.getElementById('resetPinModal').addEventListener('click', function(e) {
            if (e.target === this) closeResetModal();
        });
    </script>
}
