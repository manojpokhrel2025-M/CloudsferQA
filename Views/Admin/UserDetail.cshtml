@model CloudsferQA.Models.ViewModels.AdminUserDetailViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "User — " + Model.User.Email;

    int totalTested  = Model.Sessions.Sum(s => s.Tested);
    int totalPass    = Model.Sessions.Sum(s => s.Pass);
    int totalFail    = Model.Sessions.Sum(s => s.Fail);
    int totalBlocked = Model.Sessions.Sum(s => s.Blocked);
    double overallPR = Model.Sessions.Count > 0 && Model.Sessions.Sum(s => s.Total) > 0
        ? Math.Round((double)totalPass / Model.Sessions.Sum(s => s.Total) * 100, 1) : 0;
}

<div class="dash-hero">
    <div class="dash-hero-inner">
        <img src="/images/logo.svg" alt="Cloudsfer" height="34" class="dash-logo">
        <div>
            <h1 class="dash-title">User Detail</h1>
            <p class="dash-subtitle">
                <a href="/Admin" style="color:rgba(255,255,255,.75);text-decoration:none">← Back to User Management</a>
            </p>
        </div>
    </div>
</div>

<div class="container-fluid px-4 py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- User profile card -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6">
            <div class="dash-card h-100">
                <div class="dash-card-title">Profile</div>
                <table style="width:100%;font-size:14px;border-collapse:collapse">
                    <tr>
                        <td style="padding:7px 0;color:#90A4AE;width:110px;font-weight:600">Email</td>
                        <td style="padding:7px 0;font-weight:600">@Model.User.Email</td>
                    </tr>
                    <tr>
                        <td style="padding:7px 0;color:#90A4AE;font-weight:600">Role</td>
                        <td style="padding:7px 0">
                            <span class="admin-role-badge role-@(Model.User.Role.ToLower())">@Model.User.Role</span>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:7px 0;color:#90A4AE;font-weight:600">Status</td>
                        <td style="padding:7px 0">
                            @if (Model.User.IsEmailVerified)
                            { <span class="status-pill pill-done">✓ Verified</span> }
                            else
                            { <span class="status-pill pill-not-started">⏳ Pending</span> }
                            &nbsp;
                            @if (Model.User.IsActive)
                            { <span class="status-pill pill-in-progress">Active</span> }
                            else
                            { <span class="status-pill" style="background:#FFEBEE;color:#C62828">Disabled</span> }
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:7px 0;color:#90A4AE;font-weight:600">Joined</td>
                        <td style="padding:7px 0">@Model.User.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                    </tr>
                    @if (Model.User.VerifiedAt.HasValue)
                    {
                        <tr>
                            <td style="padding:7px 0;color:#90A4AE;font-weight:600">Verified</td>
                            <td style="padding:7px 0">@Model.User.VerifiedAt.Value.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        </tr>
                    }
                </table>

                <!-- Change Role -->
                <div style="margin-top:20px;padding-top:16px;border-top:1px solid #ECEFF1">
                    <div style="font-size:12px;font-weight:700;color:#90A4AE;text-transform:uppercase;letter-spacing:.04em;margin-bottom:10px">
                        Change Role
                    </div>
                    <form method="post" action="/Admin/SetRole" class="d-flex gap-2 align-items-center flex-wrap">
                        <input type="hidden" name="userId" value="@Model.User.Id">
                        <select name="role" class="session-select" style="min-width:120px;padding:6px 10px">
                            @foreach (var r in new[] { "QA", "Dev", "SubAdmin", "Admin" })
                            {
                                if (Model.User.Role == r)
                                {
                                    <option value="@r" selected>@r</option>
                                }
                                else
                                {
                                    <option value="@r">@r</option>
                                }
                            }
                        </select>
                        <button type="submit" class="admin-btn admin-btn-view">Save</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Activity stats -->
        <div class="col-12 col-md-6">
            <div class="row g-3 h-100 align-content-start">
                <div class="col-6">
                    <div class="kpi-card kpi-total">
                        <div class="kpi-label">Sessions</div>
                        <div class="kpi-value">@Model.Sessions.Count</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="kpi-card kpi-pass">
                        <div class="kpi-label">Pass Rate</div>
                        <div class="kpi-value" style="font-size:24px">@overallPR%</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="kpi-card kpi-pass">
                        <div class="kpi-label">Pass</div>
                        <div class="kpi-value" style="font-size:22px">@totalPass</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="kpi-card kpi-fail">
                        <div class="kpi-label">Fail</div>
                        <div class="kpi-value" style="font-size:22px">@totalFail</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="kpi-card kpi-blocked">
                        <div class="kpi-label">Blocked</div>
                        <div class="kpi-value" style="font-size:22px">@totalBlocked</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sessions table -->
    <div class="dash-card">
        <div class="dash-card-title">Test Sessions</div>

        @if (!Model.Sessions.Any())
        {
            <div class="text-center text-muted py-4">This user has not run any test sessions yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="module-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Version</th>
                            <th>Environment</th>
                            <th class="text-center">Total</th>
                            <th class="text-center">Pass</th>
                            <th class="text-center">Fail</th>
                            <th class="text-center">Blocked</th>
                            <th class="text-center">Tested</th>
                            <th style="min-width:130px">Progress</th>
                            <th class="text-center">Pass Rate</th>
                            <th>Started</th>
                            <th class="text-center">Export</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Sessions)
                        {
                            double pct = s.Total > 0 ? (double)s.Tested / s.Total * 100 : 0;
                            string barColor = s.PassRate >= 80 ? "#2E7D32" : s.PassRate >= 50 ? "#E65100" : "#C62828";
                            <tr>
                                <td><span class="badge-tc">@s.Session.Id</span></td>
                                <td style="font-weight:600">@s.Session.Version</td>
                                <td>@s.Session.Environment</td>
                                <td class="text-center">@s.Total</td>
                                <td class="text-center" style="color:#2E7D32;font-weight:600">@s.Pass</td>
                                <td class="text-center" style="color:#C62828;font-weight:600">@s.Fail</td>
                                <td class="text-center" style="color:#E65100;font-weight:600">@s.Blocked</td>
                                <td class="text-center">@s.Tested</td>
                                <td>
                                    <div class="table-progress-bar">
                                        <div class="table-progress-fill"
                                             style="width:@(pct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%;background:@barColor"></div>
                                    </div>
                                </td>
                                <td class="text-center" style="font-weight:700;color:@barColor">@s.PassRate%</td>
                                <td style="font-size:12px;color:#90A4AE;white-space:nowrap">
                                    @s.Session.StartedAt.ToString("yyyy-MM-dd HH:mm")
                                </td>
                                <td class="text-center">
                                    <a href="/Test/Export?sessionId=@s.Session.Id" class="admin-btn admin-btn-view">
                                        ↓ xlsx
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
